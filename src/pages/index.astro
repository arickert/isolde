---
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const pages = await getCollection('pages');
pages.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  pages.map(async (page) => {
    const { Content } = await render(page);
    return { ...page, Content };
  })
);

const currentShows = rendered.filter((p) => p.data.row === 'current');
const pastShows = rendered.filter((p) => p.data.row === 'past');
const infoPages = rendered.filter((p) => p.data.row === 'info');
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Isolde</title>
  <meta name="base" content={base} />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Goudy+Bookletter+1911&display=swap" rel="stylesheet" />
  <style set:html={`
    @font-face {
      font-family: 'Monument Grotesk Variable';
      src: url('${base}/fonts/MonumentGrotesk-Regular.woff2') format('woff2');
      font-weight: 200 1000;
      font-style: normal;
      font-display: swap;
    }
  `} />
</head>
<body>
  <div class="page">
    <h1 class="title">Isolde</h1>

    <a href="#" class="hero-link" data-window="information">
      <img
        class="hero-image"
        src={`${base}/images/Isolde_Windows_ASCII.png`}
        alt=""
        loading="eager"
      />
    </a>

    <div class="marquee-wrap">
      <div class="marquee">
        <div class="marquee-track">
          <span>Isolde is an artist-run project space for exhibitions, screenings, and experimental work.&nbsp;&nbsp;&nbsp;&nbsp;</span>
          <span>Isolde is an artist-run project space for exhibitions, screenings, and experimental work.&nbsp;&nbsp;&nbsp;&nbsp;</span>
        </div>
      </div>
    </div>

    <nav class="main-nav">
      <div class="nav-row">
        {currentShows.map((page) => (
          <a href="#" class="nav-item" data-window={page.id}>
            {page.data.icon.endsWith('.svg')
              ? <img class="nav-icon" src={`${base}${page.data.icon}`} alt="" />
              : page.data.icon}&thinsp;{page.data.title}
          </a>
        ))}
      </div>
      <div class="nav-row past-row">
        {pastShows.map((page) => (
          <a href="#" class="nav-item" data-window={page.id}>
            {page.data.title}
          </a>
        ))}
      </div>
    </nav>

    <div class="address">
      55 West 8th Street<br />
      Sixth Floor<br />
      New York, NY 10011<br />
      Sundays 12–6 and by appointment<br /><br />
      <em>Stair access only</em>
    </div>

    <div class="nav-row info-row">
      {infoPages.map((page) => (
        <a href="#" class="nav-item" data-window={page.id}>
          {page.data.icon.endsWith('.svg')
            ? <img class="nav-icon" src={`${base}${page.data.icon}`} alt="" />
            : page.data.icon}&thinsp;{page.data.title}
        </a>
      ))}
    </div>

    <div class="social">
      <a href="mailto:info@isolde.nyc"><img class="nav-icon" src={`${base}/icons/mail.svg`} alt="" />&thinsp;Email</a>
      <a href="https://www.are.na/isolde-nyc/channels"><img class="nav-icon" src={`${base}/icons/arena.svg`} alt="" />&thinsp;Are.na</a>
      <a href="https://www.instagram.com/isolde.nyc"><img class="nav-icon" src={`${base}/icons/instagram.svg`} alt="" />&thinsp;Instagram</a>
      <a href="#" class="newsletter-toggle" id="newsletter-toggle"><img class="nav-icon" src={`${base}/icons/mail.svg`} alt="" />&thinsp;Newsletter</a>
    </div>

    <div class="newsletter-overlay" id="newsletter-overlay">
      <div class="newsletter-modal">
        <div class="window-header">
          <button class="window-close" id="newsletter-close" aria-label="Close">&times;</button>
        </div>
        <div class="newsletter-modal-content">
          <h2 class="newsletter-title">Newsletter</h2>
          <form action="https://buttondown.com/api/emails/embed-subscribe/isolde" method="post" target="popupwindow">
            <input type="email" name="email" placeholder="Email address" required />
            <button type="submit">Subscribe</button>
          </form>
        </div>
      </div>
    </div>

    <div class="footer-row">
      <span class="clock" id="clock"></span>
      <a class="hit-counter" href="https://www.hitwebcounter.com/" target="_blank">
        <img src="https://hitwebcounter.com/counter/counter.php?page=21467869&style=0007&nbdigits=5&type=page&initCount=0" alt="visitor count" />
      </a>
    </div>
  </div>

  <!-- Flying objects -->
  <div class="flying-objects" id="flying-objects"></div>

  <!-- Overlay windows -->
  <div class="windows-layer">
    {rendered.map((page) => (
      <div class="window" id={`window-${page.id}`} style={`width: ${page.data.width}px;`}>
        <div class="window-header">
          <button class="window-close" aria-label="Close">&times;</button>
        </div>
        <div class="window-content">
          <h1 class="window-title">{page.data.title}</h1>
          {page.data.date && <p class="window-date">{page.data.date}</p>}
          {page.data.images && page.data.images.length > 0 && (
            <div class="window-image-top">
              <img src={page.data.images[0]} alt="" loading="lazy" />
            </div>
          )}
          <div class="window-body">
            <page.Content />
          </div>
          {page.data.images && page.data.images.length > 1 && (
            <div class="window-images">
              {page.data.images.slice(1).map((img: string) => (
                <img src={img} alt="" loading="lazy" />
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>

  <script>
    function clamp(n: number, min: number, max: number) {
      return Math.max(min, Math.min(max, n));
    }

    function isMobile() {
      return window.innerWidth <= 678;
    }

    let highestZ = 100;

    function bringToFront(win: HTMLElement) {
      highestZ++;
      win.style.zIndex = String(highestZ);
    }

    function randomizePosition(win: HTMLElement) {
      requestAnimationFrame(() => {
        const rect = win.getBoundingClientRect();
        const maxX = Math.max(0, window.innerWidth - rect.width);
        const maxY = Math.max(0, window.innerHeight - rect.height);
        const minX = Math.floor(maxX * 0.2);
        const maxX2 = Math.floor(maxX * 0.8);
        const minY = Math.floor(maxY * 0.15);
        const maxY2 = Math.floor(maxY * 0.7);
        const x = maxX2 > minX
          ? minX + Math.floor(Math.random() * (maxX2 - minX + 1))
          : Math.floor(maxX / 2);
        const y = maxY2 > minY
          ? minY + Math.floor(Math.random() * (maxY2 - minY + 1))
          : Math.floor(maxY / 2);
        win.style.left = x + 'px';
        win.style.top = y + 'px';
      });
    }

    function updateBodyScroll() {
      const anyOpen = document.querySelectorAll('.window.open').length > 0;
      document.body.classList.toggle('has-open-window', anyOpen && isMobile());
    }

    function openWindow(id: string) {
      const win = document.getElementById(`window-${id}`);
      if (!win) return;

      if (win.classList.contains('open')) {
        bringToFront(win);
        return;
      }

      win.classList.add('open');
      bringToFront(win);

      if (!isMobile()) {
        randomizePosition(win);
      }

      updateBodyScroll();
    }

    function closeWindow(win: HTMLElement) {
      win.classList.remove('open');
      updateBodyScroll();
    }

    function closeAllWindows() {
      document.querySelectorAll<HTMLElement>('.window.open').forEach((win) => {
        win.classList.remove('open');
      });
      updateBodyScroll();
    }

    // Nav + hero link clicks
    document.querySelectorAll<HTMLElement>('[data-window]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const id = el.dataset.window;
        if (id) openWindow(id);
      });
    });

    document.querySelectorAll<HTMLElement>('[data-action="home"]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        closeAllWindows();
      });
    });

    // Close buttons
    document.querySelectorAll<HTMLButtonElement>('.window-close').forEach((btn) => {
      btn.addEventListener('click', () => {
        const win = btn.closest('.window') as HTMLElement | null;
        if (win) closeWindow(win);
      });
    });

    // Pointer-based dragging (matches Cargo behavior)
    document.querySelectorAll<HTMLElement>('.window').forEach((win) => {
      let dragging = false;
      let startX = 0, startY = 0;
      let originLeft = 0, originTop = 0;

      win.addEventListener('pointerdown', (e) => {
        if (isMobile()) return;
        if ((e.target as HTMLElement).closest('a, button, input, textarea, select, img')) return;

        dragging = true;
        win.classList.add('is-dragging');
        win.setPointerCapture(e.pointerId);
        bringToFront(win);

        const rect = win.getBoundingClientRect();
        startX = e.clientX;
        startY = e.clientY;
        originLeft = rect.left;
        originTop = rect.top;
      });

      win.addEventListener('pointermove', (e) => {
        if (!dragging) return;
        const rect = win.getBoundingClientRect();
        const dx = e.clientX - startX;
        const dy = e.clientY - startY;
        const newLeft = originLeft + dx;
        const newTop = originTop + dy;
        const maxLeft = window.innerWidth - rect.width;
        const maxTop = window.innerHeight - rect.height;
        win.style.left = clamp(newLeft, 0, maxLeft) + 'px';
        win.style.top = clamp(newTop, 0, maxTop) + 'px';
      });

      const stop = (e: PointerEvent) => {
        if (!dragging) return;
        dragging = false;
        win.classList.remove('is-dragging');
        try { win.releasePointerCapture(e.pointerId); } catch {}
      };

      win.addEventListener('pointerup', stop);
      win.addEventListener('pointercancel', stop);
    });

    // Clamp windows to viewport on resize
    window.addEventListener('resize', () => {
      document.querySelectorAll<HTMLElement>('.window.open').forEach((win) => {
        if (isMobile()) return;
        const rect = win.getBoundingClientRect();
        const maxLeft = Math.max(0, window.innerWidth - rect.width);
        const maxTop = Math.max(0, window.innerHeight - rect.height);
        win.style.left = clamp(rect.left, 0, maxLeft) + 'px';
        win.style.top = clamp(rect.top, 0, maxTop) + 'px';
      });
    });

    // Live clock
    function updateClock() {
      const el = document.getElementById('clock');
      if (!el) return;
      const now = new Date();
      const opts: Intl.DateTimeFormatOptions = {
        weekday: 'long',
        month: 'long',
        day: 'numeric',
        year: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
      };
      el.textContent = now.toLocaleString('en-US', opts);
    }
    updateClock();
    setInterval(updateClock, 1000);

    // Newsletter modal
    const nlToggle = document.getElementById('newsletter-toggle');
    const nlOverlay = document.getElementById('newsletter-overlay');
    const nlClose = document.getElementById('newsletter-close');

    nlToggle?.addEventListener('click', (e) => {
      e.preventDefault();
      nlOverlay?.classList.add('open');
    });

    nlClose?.addEventListener('click', () => {
      nlOverlay?.classList.remove('open');
    });

    nlOverlay?.addEventListener('click', (e) => {
      if (e.target === nlOverlay) {
        nlOverlay.classList.remove('open');
      }
    });

    // Flying objects
    const base = document.querySelector('meta[name="base"]')?.getAttribute('content') || '';
    const flyingImages = [
      `${base}/images/288797042_123207673541864_8263222230316696005_n.jpg`,
      `${base}/images/Talia_Site_Image.jpeg`,
    ];

    const flyContainer = document.getElementById('flying-objects');

    interface FlightPath {
      startX: number; startY: number;
      endX: number; endY: number;
    }

    function randomFlightPath(): FlightPath {
      const w = window.innerWidth;
      const h = window.innerHeight;
      const margin = 150;

      const edges = [
        { x: -margin, y: Math.random() * h },
        { x: w + margin, y: Math.random() * h },
        { x: Math.random() * w, y: -margin },
        { x: Math.random() * w, y: h + margin },
      ];

      let start = edges[Math.floor(Math.random() * edges.length)];
      let end: { x: number; y: number };
      do {
        end = edges[Math.floor(Math.random() * edges.length)];
      } while (Math.abs(start.x - end.x) < w * 0.3 && Math.abs(start.y - end.y) < h * 0.3);

      return { startX: start.x, startY: start.y, endX: end.x, endY: end.y };
    }

    function launchFlying() {
      if (!flyContainer) return;
      const src = flyingImages[Math.floor(Math.random() * flyingImages.length)];
      const size = 60 + Math.random() * 80;
      const duration = 6000 + Math.random() * 8000;
      const rotationSpeed = (Math.random() > 0.5 ? 1 : -1) * (180 + Math.random() * 360);
      const path = randomFlightPath();

      const el = document.createElement('div');
      el.className = 'flying-obj';
      el.style.width = size + 'px';
      el.style.height = size + 'px';

      const img = document.createElement('img');
      img.src = src;
      img.alt = '';
      img.draggable = false;
      el.appendChild(img);
      flyContainer.appendChild(el);

      const startTime = performance.now();

      function animate(now: number) {
        const t = Math.min((now - startTime) / duration, 1);
        const x = path.startX + (path.endX - path.startX) * t;
        const y = path.startY + (path.endY - path.startY) * t;
        const rot = rotationSpeed * t;
        el.style.transform = `translate(${x}px, ${y}px) rotate(${rot}deg)`;

        if (t < 1) {
          requestAnimationFrame(animate);
        } else {
          el.remove();
        }
      }

      requestAnimationFrame(animate);
    }

    function scheduleNext() {
      const delay = 3000 + Math.random() * 6000;
      setTimeout(() => {
        launchFlying();
        scheduleNext();
      }, delay);
    }

    setTimeout(() => {
      launchFlying();
      scheduleNext();
    }, 2000);
  </script>
</body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Monument Grotesk Variable', system-ui, -apple-system, sans-serif;
    background: #fff;
    color: rgba(0, 0, 0, 0.85);
    min-height: 100vh;
    line-height: 1.2;
    font-size: 1.1rem;
    font-weight: 400;
    overflow: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body.has-open-window {
    overflow: hidden !important;
  }

  a {
    color: rgba(0, 0, 0, 0.85);
    text-decoration: none;
  }

  a:hover {
    color: rgba(158, 145, 145, 0.85);
  }

  a:active {
    opacity: 0.7;
  }

  /* ---- Page ---- */

  .page {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0.8rem 1rem 1.25rem;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
  }

  /* ---- Title ---- */

  .title {
    font-family: 'Goudy Bookletter 1911', Georgia, serif;
    font-size: 3.55rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
    color: rgba(158, 145, 145, 0.85);
    position: relative;
    z-index: 2;
  }

  /* ---- Hero Image ---- */

  .hero-link {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    min-height: 0;
    margin-top: 1rem;
    margin-bottom: 1.5rem;
  }

  .hero-link:hover {
    opacity: 0.85;
  }

  .hero-image {
    max-width: 95vw;
    max-height: 110%;
    width: auto;
    height: auto;
    display: block;
    object-fit: contain;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
    transform: scale(1.25);
  }

  /* ---- Marquee ---- */

  .marquee-wrap {
    max-width: 600px;
    overflow: hidden;
    margin-bottom: 0;
    position: relative;
    z-index: 2;
  }

  .marquee {
    overflow: hidden;
  }

  .marquee-track {
    display: inline-flex;
    white-space: nowrap;
    animation: marquee-scroll 10s linear infinite;
  }

  .marquee-track span {
    flex-shrink: 0;
    font-family: 'Goudy Bookletter 1911', Georgia, serif;
    font-size: 1.09rem;
    font-weight: 400;
    line-height: 1.2;
    color: rgba(0, 0, 0, 0.85);
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ---- Navigation ---- */

  .main-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    position: relative;
    z-index: 2;
  }

  .nav-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.2rem 2.5rem;
  }

  .info-row {
    margin-bottom: 0.75rem;
  }

  .past-row .nav-item {
    opacity: 0.45;
  }

  .past-row .nav-item:hover {
    opacity: 0.85;
  }

  .nav-item {
    font-family: 'Goudy Bookletter 1911', Georgia, serif;
    font-size: 1.31rem;
    font-weight: 400;
    line-height: 1.1;
    color: rgba(0, 0, 0, 0.85);
    white-space: nowrap;
    cursor: pointer;
  }

  .nav-item:hover {
    color: rgba(158, 145, 145, 0.85);
  }

  .nav-icon {
    display: inline-block;
    width: 1em;
    height: 1em;
    vertical-align: -0.15em;
  }

  /* ---- Address ---- */

  .address {
    font-size: 0.99rem;
    line-height: 1.2;
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 2;
  }

  /* ---- Social ---- */

  .social {
    display: flex;
    gap: 1.75rem;
  }

  .social a {
    font-size: 0.98rem;
    line-height: 1;
    color: rgba(0, 0, 0, 0.4);
  }

  .social .nav-icon {
    opacity: 0.4;
  }

  .social a:hover .nav-icon {
    opacity: 0.85;
  }

  .social a:hover {
    color: rgba(158, 145, 145, 0.85);
  }

  /* ---- Newsletter Modal ---- */

  .newsletter-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1100;
    background: rgba(0, 0, 0, 0.15);
    align-items: center;
    justify-content: center;
  }

  .newsletter-overlay.open {
    display: flex;
  }

  .newsletter-modal {
    background: #beb5c4;
    border: 1px solid rgba(0, 0, 0, 0.35);
    width: 340px;
    max-width: calc(100vw - 2rem);
  }

  .newsletter-modal-content {
    padding: 0 1.5rem 1.5rem;
  }

  .newsletter-title {
    font-family: 'Goudy Bookletter 1911', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 400;
    margin-bottom: 1rem;
    color: rgba(0, 0, 0, 0.85);
  }

  .newsletter-modal form {
    display: flex;
    gap: 0;
  }

  .newsletter-modal input[type="email"],
  .newsletter-modal button[type="submit"] {
    font-family: 'Monument Grotesk Variable', 'Space Grotesk', sans-serif;
    font-size: 0.9rem;
    margin: 0;
    padding: 6px 8px;
    border: 1px solid rgba(0, 0, 0, 0.25);
    border-radius: 0;
    line-height: 1;
    height: 30px;
    box-sizing: border-box;
    -webkit-appearance: none;
    appearance: none;
  }

  .newsletter-modal input[type="email"] {
    flex: 1;
    background: rgba(255, 255, 255, 0.5);
    outline: none;
    border-right: none;
    color: rgba(0, 0, 0, 0.85);
  }

  .newsletter-modal input[type="email"]:focus {
    border-color: rgba(0, 0, 0, 0.5);
  }

  .newsletter-modal input[type="email"]::placeholder {
    color: rgba(0, 0, 0, 0.3);
  }

  .newsletter-modal button[type="submit"] {
    background: transparent;
    cursor: pointer;
    color: rgba(0, 0, 0, 0.5);
    white-space: nowrap;
  }

  .newsletter-modal button[type="submit"]:hover {
    border-color: rgba(0, 0, 0, 0.5);
    color: rgba(0, 0, 0, 0.85);
  }

  /* ---- Footer Row ---- */

  .footer-row {
    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: min(1000px, 60vw);
    width: 100%;
  }

  .clock {
    font-size: 0.93rem;
    line-height: 1;
  }

  .hit-counter img {
    height: 0.6rem;
    display: block;
  }

  /* ---- Flying Objects ---- */

  .flying-objects {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 900;
  }

  .flying-obj {
    position: absolute;
    pointer-events: none;
    user-select: none;
    will-change: transform;
  }

  .flying-obj img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* ---- Windows ---- */

  .windows-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1000;
  }

  .window {
    display: none;
    position: absolute;
    max-width: calc(100vw - 2rem);
    max-height: 80vh;
    background: #beb5c4;
    border: 1px solid rgba(0, 0, 0, 0.35);
    flex-direction: column;
    overflow: hidden;
    pointer-events: auto;
    touch-action: none;
    cursor: grab;
  }

  .window.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .window.open {
    display: flex;
  }

  .window-header {
    display: flex;
    justify-content: flex-end;
    padding: 0.75rem 1rem 0;
    flex-shrink: 0;
  }

  .window-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: rgba(0, 0, 0, 0.85);
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: opacity 0.15s;
  }

  .window-close:hover {
    opacity: 0.5;
  }

  .window-content {
    padding: 0 2rem 2rem;
    overflow-y: auto;
    flex: 1;
    cursor: auto;
    text-align: left;
  }

  .window-title {
    font-family: 'Goudy Bookletter 1911', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1;
    color: rgba(1, 1, 1, 0.85);
    margin-bottom: 0.5rem;
